# EyeQ Innovate Backend Configuration
# Copy this to .env to configure cloud production services

# Server Settings
PROJECT_NAME="EyeQ Innovate API"

# Google Cloud SQL (PostgreSQL) Database settings
# If CLOUDSQL_IP is set, the API connects to Google Cloud SQL. Otherwise, it defaults to local SQLite.
CLOUDSQL_USER="postgres"
CLOUDSQL_PASSWORD="your-db-password"
CLOUDSQL_IP="" # Put your Cloud SQL instance public IP here
CLOUDSQL_DB="eyeq-cbeda-2-database"

# Alternatively, you can override by setting a direct DATABASE_URL connection string:
# DATABASE_URL="postgresql://postgres:your-db-password@your-cloudsql-ip:5432/eyeq-cbeda-2-database"

# Firebase Admin Credentials
# If BYPASS_FIREBASE_AUTH=True, these credentials are not required
BYPASS_FIREBASE_AUTH=True
FIREBASE_PROJECT_ID="eyeq-innovate"

# AWS S3 Storage Settings
# If empty, images are uploaded and served locally from backend/static/uploads
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_S3_BUCKET="your_s3_bucket"

# Llama 3 Medical Assistant (Groq Cloud API)
# If empty, a local diagnostic rules-engine chatbot is triggered as fallback
LLAMA_API_KEY=""
LLAMA_API_URL="https://api.groq.com/openai/v1/chat/completions"
